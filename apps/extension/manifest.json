{
  "manifest_version": 3,
  "name": "NeuroFlow AI Assistant",
  "version": "1.0",
  "description": "An intelligent execution assistant that understands and acts on your behalf.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_title": "NeuroFlow AI"
  }
}
